# core/ (v2 native engine spike) - build output and scratch runs, never
# secrets: run-spike.sh reads CENT_SECRET from the environment and only
# ever writes it into a generated accounts file under a scratch dir.
core/deps/re/build/
core/deps/baresip/build/
core/deps/*/build/
core/modules/ctrl_json/test/build/
core/**/*.o
core/**/*.so
core/**/*.dylib
centinelo-spike.*/
*.baresip-scratch/
graphify-out/

# shell/dist-injected/ - Windows installer resource staging (F5 packaging,
# scripts/package-official.sh + shell/src-tauri/tauri.official.conf.json).
# Populated by CI (or locally, from a private-repo checkout + Felix's
# offline-signed dylib) right before `tauri build --config
# tauri.official.conf.json` - never contains anything checked into this
# public repo, and must never be committed.
shell/dist-injected/
