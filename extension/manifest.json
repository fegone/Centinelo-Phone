{
  "manifest_version": 3,
  "name": "Centinelo Click-to-Call",
  "version": "1.0.0",
  "description": "Detects phone numbers on any page and dials them in the Centinelo Phone desktop app.",
  "permissions": ["storage"],
  "host_permissions": ["http://127.0.0.1/*"],
  "background": { "service_worker": "sw.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
