{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Centinelo Phone",
  "version": "2.0.0",
  "identifier": "com.centinelo.phone",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Centinelo Phone",
        "width": 380,
        "height": 680,
        "minWidth": 340,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["centinelo", "tel"]
      }
    }
  }
}
