{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Centinelo Phone",
  "version": "2.0.0",
  "identifier": "com.centinelo.phone",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Centinelo Phone",
        "width": 380,
        "height": 680,
        "minWidth": 340,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "publisher": "Centinelo",
    "copyright": "Copyright (c) 2026 Centinelo",
    "shortDescription": "SIP softphone with live BLF console and local transcription",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": "entitlements.plist",
      "signingIdentity": null
    },
    "windows": {
      "digestAlgorithm": "sha256",
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["centinelo", "tel"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/fegone/Centinelo-Phone/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      },
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENDNDk4N0VCQjc3N0RBRUIKUldUcjJuZTM2NGRKekpITkJNcjFDbUZQN25OcUxHZFY3aHFvODVSMWhTK1JDTHkrS0w3aVRCbUsK"
    }
  }
}
